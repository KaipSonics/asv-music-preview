# Пример переменных окружения. Скопируй в .env.local и впиши реальные значения.
# .env.local в git НЕ попадает (см. .gitignore). Реальные ключи задаём в Railway → Variables.

# Провайдер генерации:
#   genapi      — GenAPI/Suno (боевой, оплата рублями)
#   demo        — демо-клипы без реальной генерации (для разработки/превью)
#   fal | replicate | huggingface — альтернативы
AUDIO_PROVIDER=genapi

# Ключ GenAPI — https://gen-api.ru/account/api-tokens
GENAPI_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Модель GenAPI (по умолчанию suno)
GENAPI_MODEL=suno

# --- Альтернативные провайдеры (нужны только если выбран соответствующий AUDIO_PROVIDER) ---
# FAL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxx
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
