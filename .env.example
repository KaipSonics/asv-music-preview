# Пример переменных окружения. Скопируй в .env.local и впиши реальные значения.
# .env.local в git НЕ попадает (см. .gitignore). Реальные токены задаём в Railway → Variables.

# Какой провайдер генерации использовать:
#   fal         — fal.ai (по умолчанию, стартовые бесплатные кредиты)
#   replicate   — Replicate (платно, качество выше)
#   huggingface — устар. (serverless MusicGen закрыли)
AUDIO_PROVIDER=fal

# Ключ fal.ai — https://fal.ai/dashboard/keys
FAL_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# (опц.) модель и длительность хука в секундах
# FAL_MODEL=fal-ai/stable-audio
# FAL_SECONDS=15

# Нужно только если AUDIO_PROVIDER=replicate
# REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxx

# Нужно только если AUDIO_PROVIDER=huggingface
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
